# ============================================================
# EXEMPLO DE VARIÁVEIS DE AMBIENTE — copie para .env e preencha
# NUNCA commite o arquivo .env com valores reais
# ============================================================

# --- Banco de dados principal (api-usuarios, api-agencias, api-vistos) ---
POSTGRES_MAIN_USER=admin
POSTGRES_MAIN_PASSWORD=troque_por_senha_forte

# --- Banco de dados de pedidos ---
POSTGRES_PEDIDOS_USER=postgres
POSTGRES_PEDIDOS_PASSWORD=troque_por_senha_forte

# --- RabbitMQ ---
RABBITMQ_USER=troque_usuario
RABBITMQ_PASS=troque_por_senha_forte

# --- JWT Secret (mínimo 32 caracteres, use um UUID ou senha aleatória) ---
JWT_SECRET_KEY=troque-por-chave-secreta-forte-com-minimo-32-chars

# JWT_SECRET_KEY_BASE64 deve ser o base64 de JWT_SECRET_KEY
# Gere com: echo -n "sua-chave-aqui" | base64
JWT_SECRET_KEY_BASE64=base64_da_chave_acima

# --- CORS (origens permitidas separadas por vírgula) ---
# Em produção adicione a URL do frontend (ex: http://54.233.207.181:4200)
# O gateway Nginx está na porta 80; o frontend fica na 4200
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://54.233.207.181:4200
